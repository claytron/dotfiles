{{- $work := promptBoolOnce . "work" "Is this a work machine" (eq .chezmoi.hostname "charon") -}}
{{- $opAccount := promptStringOnce . "op_account" "1Password personal account ID (leave empty for none)" (dig "op_account" "" .) -}}
{{- $opAccountWork := promptStringOnce . "op_account_work" "1Password work account ID (leave empty for none)" (dig "op_account_work" "" .) -}}
{{- $opWorkPubKeyRef := promptStringOnce . "op_work_pub_key_ref" "1Password reference to work ssh public key NO QUOTES (leave empty for none)" (dig "op_work_pub_key_ref" "" .) -}}

[data]
    work = {{ $work }}
    op_account = {{ $opAccount | quote }}
    op_account_work = {{ $opAccountWork | quote }}
    op_work_pub_key_ref = {{ $opWorkPubKeyRef | quote }}

[diff]
    command = "delta"
    exclude = ["scripts"]

[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]

#!/usr/bin/env bash
set -euo pipefail

command -v claude >/dev/null || { echo "claude not installed, skipping plugins"; exit 0; }

marketplaces=(
  anthropics/claude-plugins-official
  Digital-Process-Tools/claude-marketplace
{{- if .work }}
{{- else }}
  homeassistant-ai/skills
{{- end }}
)

plugins=(
  remember@dpt-plugins
  claude-md-management@claude-plugins-official
  superpowers@claude-plugins-official
{{- if .work }}
{{- else }}
  home-assistant-skills@home-assistant-skills
{{- end }}
)

for m in "${marketplaces[@]}"; do
  claude plugin marketplace add "$m"
done

for p in "${plugins[@]}"; do
  claude plugin install "$p"
  # There is no update flag for install...
  claude plugin update "$p"
done

#!/usr/bin/env bash
# chezmoi modify_ script — maintains the notify.sh hook entries in
# ~/.claude/settings.json without touching anything else (model, plugins,
# theme, etc. all pass through). Idempotent: strips any existing notify.sh
# entries before appending fresh ones.

set -euo pipefail

input=$(cat)
[ -z "$input" ] && input='{}'

NOTIFY_CMD="~/.claude/hooks/notify.sh"
NOTIFY_BLOCK='{"hooks":[{"type":"command","command":"'"$NOTIFY_CMD"'","timeout":5}]}'

printf '%s' "$input" | jq --argjson block "$NOTIFY_BLOCK" --arg cmd "$NOTIFY_CMD" '
  .hooks //= {}
  | .hooks.Notification = (
      ((.hooks.Notification // [])
        | map(.hooks |= map(select(.command != $cmd)))
        | map(select((.hooks // []) | length > 0)))
      + [$block]
    )
  | .hooks.Stop = (
      ((.hooks.Stop // [])
        | map(.hooks |= map(select(.command != $cmd)))
        | map(select((.hooks // []) | length > 0)))
      + [$block]
    )
'
